{
  "ConnectionStrings": {
    //"DefaultConnection": "Server=localhost;Database=Prime_Framework_DB;Trusted_Connection=True;TrustServerCertificate=true;"
    "DefaultConnection": "Server=localhost,1433;Database=Prime_Framework_DB;User Id=sa;Password=YourStrong!Passw0rd;TrustServerCertificate=True"
  },


  "Serilog": {
    "Using": [ "SeriLog.Sinks.Console", "Serilog.Sinks.FiLe" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Information",
        "Microsoft.EntityFrameworkCore.Database.Connection": "Information",
        "Microsoft.EntityFrameworkCore.Query": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "Path": "Logs/MyLog_FileJSON_.json",
          "rollingInterval": "Day"
        }
      }
    ],

    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },

  "AllowedHosts": "*"
}
